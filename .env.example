# .env.example — Required environment variables for ClaimAssist.
# Copy to .env (gitignored) and fill in real values before running.
#
# For docker-compose: use service hostnames (postgres, ollama).
# For local dev without docker-compose: use localhost.

# --- Database ---
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/claimassist
SPRING_DATASOURCE_USERNAME=claimassist
SPRING_DATASOURCE_PASSWORD=change_me

# --- Ollama (model provider) ---
SPRING_AI_OLLAMA_BASE_URL=http://ollama:11434

# --- Model names (must be pulled locally: `ollama pull <model>`) ---
CLAIMASSIST_CHAT_MODEL=llama3.1
CLAIMASSIST_EMBED_MODEL=nomic-embed-text
